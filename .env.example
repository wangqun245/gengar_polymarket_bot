# PolyBot environment template
# Copy this file to .env and replace placeholder values before live trading.
# Never commit your real .env file or private key.

# Required wallet settings
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
SAFE_ADDRESS=0xYOUR_POLYMARKET_SAFE_ADDRESS_HERE
FUNDER_ADDRESS=0xYOUR_POLYMARKET_API_OR_FUNDER_ADDRESS_HERE
SIGNATURE_TYPE=3
DRY_RUN=true

# Strategy
MIN_EDGE=0.05
MIN_PROB=0.80
MIN_BTC_DELTA=0.06
SAFETY_FACTOR=0.85
ENTRY_WINDOW_START=240
ENTRY_WINDOW_END=10
KELLY_FRACTION=0.25
MIN_BET=5.0
MAX_BET=25.0
BANKROLL=100.0

# Dynamic volatility
ROLLING_VOL_WINDOWS=12
VOL_FLOOR=0.06
VOL_CAP=0.30

# Safety
DAILY_LOSS_LIMIT=30.0

# Notifications
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# Other
MARKET_PERIOD=5
LOG_DIR=logs
LOG_EXECUTIONS=false
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=
