# Required
PRIVATE_KEY=0x...
SAFE_ADDRESS=0x...
SIGNATURE_TYPE=2
DRY_RUN=true

# Trading
MARKET_PERIOD=5
ENTRY_WINDOW_SECONDS=240
DRY_RUN_BALANCE=100
TRADE_AMOUNT=5.00
MAX_BUY_PRICE=0.60
MIN_PROFIT_PCT=0.06
PROFIT_RETREAT_PCT=0.35
DAILY_LOSS_LIMIT=30
STRATEGY_PEAK_LOSS_DROP=0
STRATEGY_COOLING_DOWN_PERIOD=5400

# Binance 50ms latency strategy
LATENCY_BUCKET_MS=50
LATENCY_BASELINE_HOURS=3
LATENCY_MIN_BASELINE_BUCKETS=300
LATENCY_WARMUP_MINUTES=10
LATENCY_MIN_WARMUP_BUCKETS=300
LATENCY_ENTRY_PRICE_Z=3.0
LATENCY_ENTRY_VOLUME_Z=1.5
LATENCY_ENTRY_VOLUME_ADAPTIVE=true
LATENCY_ENTRY_VOLUME_ADAPTIVE_MINUTES=30
LATENCY_ENTRY_VOLUME_ADAPTIVE_TOP_N=6
LATENCY_ENTRY_VOLUME_ADAPTIVE_BEAT_COUNT=3
LATENCY_ENTRY_VOLUME_ADAPTIVE_MIN_Z=0.50
LATENCY_EXIT_PRICE_Z=2.5
LATENCY_EXIT_VOLUME_Z=2.5
LATENCY_ENTRY_MIN_PRICE_MOVE_PCT=0.015
LATENCY_EXIT_MIN_PRICE_MOVE_PCT=0.010
LATENCY_ENTRY_MIN_QTY=0
LATENCY_EXIT_MIN_QTY=0
LATENCY_PUSH_STD_MINUTES=10
LATENCY_PUSH_STD_MIN_SAMPLES=120
LATENCY_PUSH_SIGNAL_MS=1000
LATENCY_PUSH_SIGNAL_MIN_SAMPLES=3
LATENCY_ENTRY_PUSH_STD_MULT=2.5
LATENCY_EXIT_PUSH_STD_MULT=2.5

# Binance -> Polymarket latency sync
CHANNEL_LATENCY_DEFAULT_MS=300
CHANNEL_LATENCY_MAX_WAIT_MS=1500
CHANNEL_LATENCY_POLY_SYNC_MIN_MOVE=0.005
CHANNEL_LATENCY_POLY_TREND_DELAY_MS=0
CHANNEL_LATENCY_POLY_TREND_TICKS=3
CHANNEL_LATENCY_POLY_TREND_WINDOW_MS=150
CHANNEL_LATENCY_SAFETY_MARGIN_MS=200
CHANNEL_LATENCY_SAMPLE_LIMIT=100
CHANNEL_WAVEFORM_SAMPLE_MS=50
CHANNEL_WAVEFORM_START_OFFSET_SECONDS=10
CHANNEL_WAVEFORM_MATCH_SECONDS=120
CHANNEL_WAVEFORM_MAX_LAG_SECONDS=5
CHANNEL_WAVEFORM_LAG_STEP_MS=100
CHANNEL_WAVEFORM_MIN_POINTS=1500
CHANNEL_WAVEFORM_MAX_SAMPLE_DEVIATION_MS=250
CHANNEL_WAVEFORM_MIN_ACCEPT_MS=250
CHANNEL_WAVEFORM_MAX_ACCEPT_MS=1500
CHANNEL_WAVEFORM_MIN_BASELINE_SAMPLES=3
CHANNEL_WAVEFORM_MAX_SAMPLE_GAP_SECONDS=30
CHANNEL_WAVEFORM_MIN_SSE_IMPROVEMENT=1.0
CHANNEL_WAVEFORM_MIN_SSE_IMPROVEMENT_PCT=0.001
CHANNEL_WAVEFORM_MIN_POLY_RANGE=0.50
CHANNEL_WAVEFORM_MAX_SCALE=350

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TITLE_SUFFIX=_EU

# Runtime
STATUS_INTERVAL_SECONDS=10
LOG_DIR=logs
