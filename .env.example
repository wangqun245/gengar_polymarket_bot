# PolyBot environment template
# Copy this file to .env and replace placeholder values before live trading.
# Never commit your real .env file or private key.

# Required wallet settings
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
SAFE_ADDRESS=0xYOUR_POLYMARKET_SAFE_ADDRESS_HERE
FUNDER_ADDRESS=0xYOUR_POLYMARKET_API_OR_FUNDER_ADDRESS_HERE
SIGNATURE_TYPE=3
DRY_RUN=true

# Strategy
MIN_EDGE=0.05
MIN_PROB=0.80
MIN_BTC_DELTA=0.06
SAFETY_FACTOR=0.85
ENTRY_WINDOW_START=240
ENTRY_WINDOW_END=10
KELLY_FRACTION=0.25
MIN_BET=5.0
MAX_BET=25.0
BANKROLL=100.0

# Binance trend entry mode
# During the first 60s of each 5-minute event, wait until BTC moves at least
# TREND_ENTRY_THRESHOLD_PCT from the window open. If it already moved beyond
# TREND_ENTRY_SKIP_THRESHOLD_PCT, skip that event instead of chasing.
TREND_ENTRY_WINDOW_SECONDS=60
TREND_ENTRY_THRESHOLD_PCT=0.03
TREND_ENTRY_SKIP_THRESHOLD_PCT=0.20
TREND_TRADE_AMOUNT=25.0
INVERT_TREND_ENTRY=false
MAX_BUY_PRICE=0.90

# Polymarket real-time price feed + profit exits
POLYMARKET_WS_ENABLED=true
POLYMARKET_WS_WARMUP_SECONDS=2.0
TAKE_PROFIT_PRICE=0.70
MIN_PROFIT_PCT=0.10
MIN_PROFIT_USD=1.00
TREND_PROFIT_RETREAT_PCT=0.20
CONFIRM_WS_SELL_PRICE=true

# Secondary strategy: cheap Polymarket price scalp
# Watches live UP/DOWN asks during the first half of the window. If either
# side is executable at or below CHEAP_ENTRY_PRICE, buy it and use the same
# take-profit settings above for exit.
CHEAP_SCALP_ENABLED=true
CHEAP_ENTRY_PRICE=0.20
CHEAP_ENTRY_WINDOW_SECONDS=150
CHEAP_TRADE_AMOUNT=25.0
CHEAP_BUY_TAKE_PROFIT_PRICE=0.30
CHEAP_BUY_MIN_PROFIT_PCT=0.10
CHEAP_BUY_MIN_PROFIT_USD=1.00
CHEAP_PROFIT_RETREAT_PCT=0.20

# Third strategy: panic rebound buy
PANIC_BUY_ENABLED=true
PANIC_LOOKBACK_SECONDS=20
PANIC_DROP_PCT=0.25
PANIC_MAX_BUY_PRICE=0.45
PANIC_MAX_BTC_AGAINST_PCT=0.08
PANIC_ENTRY_WINDOW_SECONDS=240
PANIC_TRADE_AMOUNT=25.0
PANIC_TAKE_PROFIT_PRICE=0.55
PANIC_MIN_PROFIT_PCT=0.12
PANIC_MIN_PROFIT_USD=1.00
PANIC_PROFIT_RETREAT_PCT=0.20

# Fourth strategy: Binance/Polymarket relative overreaction
REALTIME_TO_SAVE=120
RELATIVE_REACTION_ENABLED=true
RELATIVE_ENTRY_WINDOW_SECONDS=120
RELATIVE_LOOKBACK_SECONDS=120
RELATIVE_MIN_BTC_MOVE_PCT=0.02
RELATIVE_OVERREACTION_PRICE=0.10
RELATIVE_TRADE_AMOUNT=25.0
RELATIVE_MIN_BUY_PRICE=0.05
RELATIVE_MAX_BUY_PRICE=0.65
RELATIVE_TAKE_PROFIT_PRICE=0.55
RELATIVE_MIN_PROFIT_PCT=0.10
RELATIVE_MIN_PROFIT_USD=1.00
RELATIVE_PROFIT_RETREAT_PCT=0.20

# Dynamic volatility
ROLLING_VOL_WINDOWS=12
VOL_FLOOR=0.06
VOL_CAP=0.30

# Safety
DAILY_LOSS_LIMIT_RETREAT=30.0
PEAK_LOSS_DROP=30.0
COOLING_DOWN_PERIOD=10800
TREND_DAILY_LOSS_LIMIT=30.0
TREND_PEAK_LOSS_DROP=20.0
TREND_COOLING_DOWN_PERIOD=5400
CHEAP_DAILY_LOSS_LIMIT=30.0
CHEAP_PEAK_LOSS_DROP=20.0
CHEAP_COOLING_DOWN_PERIOD=5400
PANIC_DAILY_LOSS_LIMIT=30.0
PANIC_PEAK_LOSS_DROP=20.0
PANIC_COOLING_DOWN_PERIOD=5400
RELATIVE_DAILY_LOSS_LIMIT=30.0
RELATIVE_PEAK_LOSS_DROP=20.0
RELATIVE_COOLING_DOWN_PERIOD=5400

# Notifications
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# Other
MARKET_PERIOD=5
LOG_DIR=logs
LOG_EXECUTIONS=false
BOT_RUNTIME_LOG_ENABLED=true
BOT_RUNTIME_LOG_FILE=

# CLOB auth
# Keep CLOB_CREDS_MODE=auto unless you have SDK-derived CLOB L2 credentials.
# Polymarket "Relayer API Keys" are different and should not be pasted here.
CLOB_CREDS_MODE=auto
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
